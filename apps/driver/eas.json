{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "BUN_VERSION": "1.0.x",
        "EXPO_PUBLIC_API_URL": "http://192.168.1.100:3000"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "BUN_VERSION": "1.0.x",
        "EXPO_PUBLIC_API_URL": "https://nammabus-api.onrender.com"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "BUN_VERSION": "1.0.x",
        "EXPO_PUBLIC_API_URL": "https://nammabus-api.onrender.com"
      }
    }
  }
}
