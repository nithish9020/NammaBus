{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "outDir": "dist",
    "rootDir": ".",
    "strict": false,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "identity/**/*", "mobility/**/*", "realtime/**/*", "prediction/**/*"],
  "exclude": ["node_modules", "dist"]
}
